# Supabase Postgres — Project Settings → Database → Connection string
#
# DATABASE_URL: Transaction pooler (port 6543). Used by the app at runtime.
#   Mode: Transaction · add ?pgbouncer=true so Prisma doesn't use prepared statements.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# DIRECT_URL: Session pooler (port 5432) or Direct connection.
#   Used only by `prisma migrate` (needs a non-transaction-pooler link).
#   Session pooler:
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
#   Or direct (IPv6-only on free tier — use Session pooler if migrate fails):
# DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"
#
# Shared secret guarding /api/ingest. On Vercel, name it CRON_SECRET and
# Vercel Cron will send it automatically as "Authorization: Bearer <value>".
CRON_SECRET="change-me"
